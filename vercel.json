{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/inventory.html"
    },
    {
      "source": "/products",
      "destination": "/api/index.js"
    },
    {
      "source": "/products/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/bill",
      "destination": "/api/index.js"
    },
    {
      "source": "/bills",
      "destination": "/api/index.js"
    }
  ]
}
