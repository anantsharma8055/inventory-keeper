{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/inventory.html"
    },
    {
      "src": "/products",
      "dest": "server.js"
    },
    {
      "src": "/products/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/bill",
      "dest": "server.js"
    },
    {
      "src": "/bills",
      "dest": "server.js"
    }
  ]
}
