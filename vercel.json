{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/inventory.html"
    },
    {
      "source": "/products",
      "destination": "/server.js"
    },
    {
      "source": "/products/:path*",
      "destination": "/server.js"
    },
    {
      "source": "/bill",
      "destination": "/server.js"
    },
    {
      "source": "/bills",
      "destination": "/server.js"
    }
  ]
}
